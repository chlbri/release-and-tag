{
  "name": "create-release",
  "version": "1.0.0",
  "description": "Create a release",
  "keywords": [
    "actions",
    "node"
  ],
  "license": "MIT",
  "author": "chlbri",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chlbri/create-tag-release"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "require": "./lib/index.cjs",
      "types": "./lib/index.d.ts"
    }
  },
  "scripts": {
    "pnpm:devPreinstall": "node -e \"const fs=require('fs'); const pkg=JSON.parse(fs.readFileSync('./package.json')); const version=require('child_process').execSync('pnpm -v').toString().trim(); pkg.packageManager='pnpm@' + version; fs.writeFileSync('./package.json', JSON.stringify(pkg, null, 2) + '\\n');\"",
    "build": "pnpm rm:lib && pnpm run rolldown",
    "_ci": "pnpm run lint && pnpm run test",
    "ci": "CI_START=$(date +%s) && pnpm run _ci && pnpm run p-q && echo \"\\n✅ CI takes $(($(date +%s) - CI_START))s\\n\"",
    "ci:admin": "CI_START=$(date +%s) && pnpm run rm && pnpm run upgrade:fast && pnpm run _ci && echo \"\\n✅ Admin CI takes $(($(date +%s) - CI_START))s\\n\"",
    "config": "pnpm install",
    "config:off": "pnpm run config --offline",
    "_lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint": "pnpm run fmt && pnpm run lint:fix",
    "lint:watch": "onchange --await-write-finish 1500 -d 10000 -v \"**/*.ts\" -- pnpm run lint",
    "build:watch": "onchange --await-write-finish 1500 -d 10000 -v \"**/*.ts\" -- pnpm run build",
    "p-q": "pretty-quick",
    "posttest": "pnpm run fmt",
    "prepublishOnly": "",
    "pretest": "pnpm run build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "rinit": "pnpm clean --lockfile && pnpm run rm && pnpm run config",
    "rinit:off": "pnpm run rm && pnpm run config:off",
    "rm": "pnpx rimraf ./node_modules ./pnpm-lock.yaml",
    "rm:lib": "pnpx rimraf ./lib",
    "rolldown": "rolldown -c",
    "test:coverage": "vitest run",
    "test": "pnpm run test:coverage",
    "test:only": "pnpm run test:coverage --no-coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "upgrade": "pnpm dlx @bemedev/upgrade-npm-package",
    "upgrade:fast": "pnpm up --latest",
    "prepare": "husky"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1"
  },
  "devDependencies": {
    "@bemedev/dev-utils": "^0.8.2",
    "@bemedev/rolldown-config": "^0.5.0",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "husky": "^9.1.7",
    "onchange": "^7.1.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "pretty-quick": "^4.2.2",
    "rimraf": "^6.1.3",
    "rolldown": "^1.1.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
